{
  "name": "drawd-mcp-server",
  "version": "1.1.0",
  "description": "MCP server for Drawd — AI agent flow builder. Create app flow designs programmatically with AI agents.",
  "type": "module",
  "bin": {
    "drawd-mcp": "./dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist/",
    "assets/"
  ],
  "scripts": {
    "build": "node build.js",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "node --import ./loader.js index.js",
    "api": "node --import ./loader.js api.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@resvg/resvg-js": "^2.6.2",
    "puppeteer-core": "^24.9.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "drawd",
    "flow-designer",
    "ai-agent",
    "app-design",
    "mobile-flow"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeflow-studio/drawd",
    "directory": "mcp-server"
  }
}
